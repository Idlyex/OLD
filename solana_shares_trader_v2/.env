# --- Polymarket Wallet ---
# PRIVATE_KEY: Your Polygon wallet private key (with 0x prefix)
#   → Get from MetaMask: Settings > Security > Export Private Key
#   → Must be activated on polymarket.com first
PRIVATE_KEY=0x6eecbb6ccb82c0ee32a08c7527880025a06a54efdf228cf71a192ec968c3d211

# PROXY_WALLET: Your Polymarket proxy/trading wallet address
#   → Found on polymarket.com > Settings > Funding > Proxy Address
#   → Required for placing orders via the proxy contract
PROXY_WALLET=0x091A6A99DBF736a7bC56901eA3da0e2433213b2E

# --- Builder / Relayer (gasless tx via Polymarket relayer) ---
# Get these from: https://gamma-api.polymarket.com (builder section)
# While daily limit is not exhausted, all tx are FREE (no gas needed)
# When exhausted, falls back to standard orders (requires MATIC for gas)
POLY_BUILDER_API_KEY=019d2be6-4afb-7c83-9c35-a8da27f8bf01
POLY_BUILDER_SECRET=XETAIOX5AB3kjRZi-m7ypJOsIOp_0i9y_99qeZuF-MQ=
POLY_BUILDER_PASSPHRASE=9c00be50eab27b3efe41d02af849c54caa49332627ff478612d46cdb146d292f

# --- Polygon RPC ---
# Public RPC (free, rate-limited). For better performance use:
#   → Alchemy: https://dashboard.alchemy.com (free tier = 300M CU/month)
#   → QuickNode: https://quicknode.com
RPC_URL=https://polygon-rpc.com

# --- Trading Mode ---
# DRY_RUN=true  → simulate trades (no real orders)
# DRY_RUN=false → LIVE trading with real USDC
DRY_RUN=false

# --- Telegram Bot ---
# TG_BOT_TOKEN: Create bot via @BotFather on Telegram
# TG_CHAT_ID: Get via @userinfobot or forwarding message to @JsonDumpBot
TG_BOT_TOKEN=8548039117:AAFEXg_wpPIULnZDy145VYpl49VarQhRp4o
TG_CHAT_ID=-5023502158 #1293953561
