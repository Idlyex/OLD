# ══════════════════════════════════════════════════════════════
#  Solana Shares Trader v2 — Environment Variables
# ══════════════════════════════════════════════════════════════

# Polymarket wallet
PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE
PROXY_WALLET=

# Polymarket Builder (for gasless tx)
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=

# Solana RPC
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PASSWORD=

# Mode override
MODE=backtest
DRY_RUN=true
